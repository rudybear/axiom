@module recursion_test;
@intent("Test recursive functions: Ackermann, Tak, factorial, and Fibonacci");

// Ackermann function — deeply recursive, grows extremely fast.
// A(0, n) = n + 1
// A(m, 0) = A(m-1, 1)
// A(m, n) = A(m-1, A(m, n-1))
@pure
fn ackermann(m: i32, n: i32) -> i32 {
    if m == 0 {
        return n + 1;
    }
    if n == 0 {
        return ackermann(m - 1, 1);
    }
    return ackermann(m - 1, ackermann(m, n - 1));
}

// Takeuchi (Tak) function — a classic recursion benchmark.
// tak(x, y, z) = y if x <= y
// tak(x, y, z) = tak(tak(x-1, y, z), tak(y-1, z, x), tak(z-1, x, y))
@pure
fn tak(x: i32, y: i32, z: i32) -> i32 {
    if x <= y {
        return y;
    }
    return tak(tak(x - 1, y, z), tak(y - 1, z, x), tak(z - 1, x, y));
}

// Factorial — classic recursive definition.
@pure
@complexity O(n)
fn factorial(n: i32) -> i64 {
    if n <= 1 {
        return 1;
    }
    return widen(n) * factorial(n - 1);
}

// Fibonacci — naive recursive (exponential time).
@pure
fn fib(n: i32) -> i32 {
    if n <= 0 {
        return 0;
    }
    if n == 1 {
        return 1;
    }
    return fib(n - 1) + fib(n - 2);
}

fn main() -> i32 {
    // Ackermann tests (small values to avoid stack overflow).
    print("Ackermann(0, 0):");
    print_i32(ackermann(0, 0));

    print("Ackermann(1, 1):");
    print_i32(ackermann(1, 1));

    print("Ackermann(2, 2):");
    print_i32(ackermann(2, 2));

    print("Ackermann(3, 3):");
    print_i32(ackermann(3, 3));

    // Tak function.
    print("Tak(18, 12, 6):");
    print_i32(tak(18, 12, 6));

    // Factorial.
    print("Factorial(10):");
    print_i64(factorial(10));

    print("Factorial(20):");
    print_i64(factorial(20));

    // Fibonacci (small values due to exponential time).
    print("Fib(10):");
    print_i32(fib(10));

    print("Fib(20):");
    print_i32(fib(20));

    print("All recursion tests complete.");
    return 0;
}

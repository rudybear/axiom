@module sort_test;
@intent("Small array sort with verification that output is correctly ordered");

// Bubble sort on a small array, then verify sorted order.
@pure
fn sort_and_verify(arr: array[i32, 20], n: i32) -> i32 {
    // Bubble sort.
    for i: i32 in range(0, n - 1) {
        for j: i32 in range(0, n - 1 - i) {
            if arr[j] > arr[j + 1] {
                let tmp: i32 = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = tmp;
            }
        }
    }
    // Verify sorted order: return 1 if sorted, 0 if not.
    for i: i32 in range(0, n - 1) {
        if arr[i] > arr[i + 1] {
            return 0;
        }
    }
    return 1;
}

fn main() -> i32 {
    let arr: array[i32, 20] = array_zeros[i32, 20];
    let n: i32 = 10;

    // Fill with values in reverse order.
    arr[0] = 42;
    arr[1] = 17;
    arr[2] = 93;
    arr[3] = 5;
    arr[4] = 28;
    arr[5] = 61;
    arr[6] = 3;
    arr[7] = 84;
    arr[8] = 39;
    arr[9] = 10;

    print("Before sort:");
    for i: i32 in range(0, n) {
        print_i32(arr[i]);
    }

    let ok: i32 = sort_and_verify(arr, n);

    print("After sort:");
    for i: i32 in range(0, n) {
        print_i32(arr[i]);
    }

    print("Sorted correctly (1=yes, 0=no):");
    print_i32(ok);

    return 0;
}

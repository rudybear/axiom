@module leibniz_pi;

fn main() -> i32 {
    let x: f64 = 1.0;
    for i: i32 in range(2, 10000001) {
        let k: i32 = i * 2 - 1;
        let d: f64 = to_f64(k);
        if i % 2 == 0 {
            x = x - 1.0 / d;
        } else {
            x = x + 1.0 / d;
        }
    }
    let pi: f64 = x * 4.0;
    print_f64(pi);
    return 0;
}

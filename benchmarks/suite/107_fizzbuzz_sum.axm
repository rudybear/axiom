@module fizzbuzz_sum;

fn main() -> i32 {
    let sum: i32 = 0;
    for i: i32 in range(1, 101) {
        if i % 15 == 0 {
            sum = sum + 15;
        } else {
            if i % 3 == 0 {
                sum = sum + 3;
            } else {
                if i % 5 == 0 {
                    sum = sum + 5;
                } else {
                    sum = sum + i;
                }
            }
        }
    }
    print_i32(sum);
    return 0;
}

@module coprimality_test;

@pure
fn gcd(a: i32, b: i32) -> i32 {
    let x: i32 = a;
    let y: i32 = b;
    while y != 0 {
        let t: i32 = y;
        y = x % y;
        x = t;
    }
    return x;
}

fn main() -> i32 {
    let count: i32 = 0;
    for i: i32 in range(1, 51) {
        if gcd(i, 30) == 1 {
            count = count + 1;
        }
    }
    print_i32(count);
    return 0;
}

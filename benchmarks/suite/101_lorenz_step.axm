@module lorenz_step;

fn main() -> i32 {
    let sigma: f64 = 10.0;
    let rho: f64 = 28.0;
    let beta: f64 = 8.0 / 3.0;
    let dt: f64 = 0.001;
    let x: f64 = 1.0;
    let y: f64 = 1.0;
    let z: f64 = 1.0;
    for i: i32 in range(0, 10000) {
        let dx: f64 = sigma * (y - x);
        let dy: f64 = x * (rho - z) - y;
        let dz: f64 = x * y - beta * z;
        x = x + dx * dt;
        y = y + dy * dt;
        z = z + dz * dt;
    }
    print_f64(x);
    return 0;
}

@module count_perfect_numbers;

@pure
fn is_perfect(n: i32) -> i32 {
    let sum: i32 = 0;
    for i: i32 in range(1, n) {
        if n % i == 0 {
            sum = sum + i;
        }
    }
    if sum == n {
        return 1;
    }
    return 0;
}

fn main() -> i32 {
    let count: i32 = 0;
    for n: i32 in range(2, 8129) {
        count = count + is_perfect(n);
    }
    print_i32(count);
    return 0;
}

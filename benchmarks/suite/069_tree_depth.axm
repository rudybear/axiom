@module tree_depth;

@pure
fn depth(n: i32) -> i32 {
    if n <= 1 {
        return 0;
    }
    let left: i32 = depth(n / 2);
    let right: i32 = depth(n - n / 2 - 1);
    if left > right {
        return left + 1;
    }
    return right + 1;
}

fn main() -> i32 {
    print_i32(depth(1000000));
    return 0;
}

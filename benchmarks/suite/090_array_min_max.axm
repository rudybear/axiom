@module array_min_max;

fn main() -> i32 {
    let arr: array[i32, 100] = array_zeros[i32, 100];
    for i: i32 in range(0, 100) {
        arr[i] = (i * 37 + 13) % 100;
    }
    let mn: i32 = arr[0];
    let mx: i32 = arr[0];
    for i: i32 in range(1, 100) {
        if arr[i] < mn {
            mn = arr[i];
        }
        if arr[i] > mx {
            mx = arr[i];
        }
    }
    print_i32(mx - mn);
    return 0;
}

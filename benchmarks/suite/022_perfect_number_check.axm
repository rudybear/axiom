@module perfect_number_check;

@pure
fn is_perfect(n: i32) -> i32 {
    let sum: i32 = 0;
    for i: i32 in range(1, n) {
        if n % i == 0 {
            sum = sum + i;
        }
    }
    if sum == n {
        return 1;
    }
    return 0;
}

fn main() -> i32 {
    print_i32(is_perfect(496));
    return 0;
}

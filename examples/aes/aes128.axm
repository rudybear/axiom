@module aes128;
@intent("AES-128 ECB mode encryption/decryption with NIST test vector verification and benchmark");

// =============================================================================
// AES-128-ECB -- Tiny-AES port to AXIOM
// =============================================================================
//
// Implements AES-128 encryption and decryption in ECB mode.
// Key size: 16 bytes (128 bits), Block size: 16 bytes, Rounds: 10
//
// GAP: AXIOM has no u8 type; we use i32 to hold byte values [0..255].
//      All byte operations mask with band(x, 255) where needed.
// GAP: No multi-dimensional arrays; state[4][4] is flat array[i32, 16].
//      Indexing: state[row][col] = state[row * 4 + col] (row-major for state).
//      Note: AES state is column-major: state[row][col] where col is the
//      byte index within a column. We store as flat[row * 4 + col].
// GAP: No static/global arrays; S-box and tables are initialized in functions.
// =============================================================================

// ---------------------------------------------------------------------------
// AES constants
// ---------------------------------------------------------------------------
@const fn NB() -> i32 { return 4; }
@const fn NK() -> i32 { return 4; }
@const fn NR() -> i32 { return 10; }
@const fn KEYLEN() -> i32 { return 16; }
@const fn KEYEXPSIZE() -> i32 { return 176; }

// ---------------------------------------------------------------------------
// S-box initialization: 256-byte AES substitution box
// ---------------------------------------------------------------------------
fn init_sbox(s: ptr[i32]) {
    // Row 0
    ptr_write_i32(s, 0, 0x63); ptr_write_i32(s, 1, 0x7C); ptr_write_i32(s, 2, 0x77); ptr_write_i32(s, 3, 0x7B);
    ptr_write_i32(s, 4, 0xF2); ptr_write_i32(s, 5, 0x6B); ptr_write_i32(s, 6, 0x6F); ptr_write_i32(s, 7, 0xC5);
    ptr_write_i32(s, 8, 0x30); ptr_write_i32(s, 9, 0x01); ptr_write_i32(s, 10, 0x67); ptr_write_i32(s, 11, 0x2B);
    ptr_write_i32(s, 12, 0xFE); ptr_write_i32(s, 13, 0xD7); ptr_write_i32(s, 14, 0xAB); ptr_write_i32(s, 15, 0x76);
    // Row 1
    ptr_write_i32(s, 16, 0xCA); ptr_write_i32(s, 17, 0x82); ptr_write_i32(s, 18, 0xC9); ptr_write_i32(s, 19, 0x7D);
    ptr_write_i32(s, 20, 0xFA); ptr_write_i32(s, 21, 0x59); ptr_write_i32(s, 22, 0x47); ptr_write_i32(s, 23, 0xF0);
    ptr_write_i32(s, 24, 0xAD); ptr_write_i32(s, 25, 0xD4); ptr_write_i32(s, 26, 0xA2); ptr_write_i32(s, 27, 0xAF);
    ptr_write_i32(s, 28, 0x9C); ptr_write_i32(s, 29, 0xA4); ptr_write_i32(s, 30, 0x72); ptr_write_i32(s, 31, 0xC0);
    // Row 2
    ptr_write_i32(s, 32, 0xB7); ptr_write_i32(s, 33, 0xFD); ptr_write_i32(s, 34, 0x93); ptr_write_i32(s, 35, 0x26);
    ptr_write_i32(s, 36, 0x36); ptr_write_i32(s, 37, 0x3F); ptr_write_i32(s, 38, 0xF7); ptr_write_i32(s, 39, 0xCC);
    ptr_write_i32(s, 40, 0x34); ptr_write_i32(s, 41, 0xA5); ptr_write_i32(s, 42, 0xE5); ptr_write_i32(s, 43, 0xF1);
    ptr_write_i32(s, 44, 0x71); ptr_write_i32(s, 45, 0xD8); ptr_write_i32(s, 46, 0x31); ptr_write_i32(s, 47, 0x15);
    // Row 3
    ptr_write_i32(s, 48, 0x04); ptr_write_i32(s, 49, 0xC7); ptr_write_i32(s, 50, 0x23); ptr_write_i32(s, 51, 0xC3);
    ptr_write_i32(s, 52, 0x18); ptr_write_i32(s, 53, 0x96); ptr_write_i32(s, 54, 0x05); ptr_write_i32(s, 55, 0x9A);
    ptr_write_i32(s, 56, 0x07); ptr_write_i32(s, 57, 0x12); ptr_write_i32(s, 58, 0x80); ptr_write_i32(s, 59, 0xE2);
    ptr_write_i32(s, 60, 0xEB); ptr_write_i32(s, 61, 0x27); ptr_write_i32(s, 62, 0xB2); ptr_write_i32(s, 63, 0x75);
    // Row 4
    ptr_write_i32(s, 64, 0x09); ptr_write_i32(s, 65, 0x83); ptr_write_i32(s, 66, 0x2C); ptr_write_i32(s, 67, 0x1A);
    ptr_write_i32(s, 68, 0x1B); ptr_write_i32(s, 69, 0x6E); ptr_write_i32(s, 70, 0x5A); ptr_write_i32(s, 71, 0xA0);
    ptr_write_i32(s, 72, 0x52); ptr_write_i32(s, 73, 0x3B); ptr_write_i32(s, 74, 0xD6); ptr_write_i32(s, 75, 0xB3);
    ptr_write_i32(s, 76, 0x29); ptr_write_i32(s, 77, 0xE3); ptr_write_i32(s, 78, 0x2F); ptr_write_i32(s, 79, 0x84);
    // Row 5
    ptr_write_i32(s, 80, 0x53); ptr_write_i32(s, 81, 0xD1); ptr_write_i32(s, 82, 0x00); ptr_write_i32(s, 83, 0xED);
    ptr_write_i32(s, 84, 0x20); ptr_write_i32(s, 85, 0xFC); ptr_write_i32(s, 86, 0xB1); ptr_write_i32(s, 87, 0x5B);
    ptr_write_i32(s, 88, 0x6A); ptr_write_i32(s, 89, 0xCB); ptr_write_i32(s, 90, 0xBE); ptr_write_i32(s, 91, 0x39);
    ptr_write_i32(s, 92, 0x4A); ptr_write_i32(s, 93, 0x4C); ptr_write_i32(s, 94, 0x58); ptr_write_i32(s, 95, 0xCF);
    // Row 6
    ptr_write_i32(s, 96, 0xD0); ptr_write_i32(s, 97, 0xEF); ptr_write_i32(s, 98, 0xAA); ptr_write_i32(s, 99, 0xFB);
    ptr_write_i32(s, 100, 0x43); ptr_write_i32(s, 101, 0x4D); ptr_write_i32(s, 102, 0x33); ptr_write_i32(s, 103, 0x85);
    ptr_write_i32(s, 104, 0x45); ptr_write_i32(s, 105, 0xF9); ptr_write_i32(s, 106, 0x02); ptr_write_i32(s, 107, 0x7F);
    ptr_write_i32(s, 108, 0x50); ptr_write_i32(s, 109, 0x3C); ptr_write_i32(s, 110, 0x9F); ptr_write_i32(s, 111, 0xA8);
    // Row 7
    ptr_write_i32(s, 112, 0x51); ptr_write_i32(s, 113, 0xA3); ptr_write_i32(s, 114, 0x40); ptr_write_i32(s, 115, 0x8F);
    ptr_write_i32(s, 116, 0x92); ptr_write_i32(s, 117, 0x9D); ptr_write_i32(s, 118, 0x38); ptr_write_i32(s, 119, 0xF5);
    ptr_write_i32(s, 120, 0xBC); ptr_write_i32(s, 121, 0xB6); ptr_write_i32(s, 122, 0xDA); ptr_write_i32(s, 123, 0x21);
    ptr_write_i32(s, 124, 0x10); ptr_write_i32(s, 125, 0xFF); ptr_write_i32(s, 126, 0xF3); ptr_write_i32(s, 127, 0xD2);
    // Row 8
    ptr_write_i32(s, 128, 0xCD); ptr_write_i32(s, 129, 0x0C); ptr_write_i32(s, 130, 0x13); ptr_write_i32(s, 131, 0xEC);
    ptr_write_i32(s, 132, 0x5F); ptr_write_i32(s, 133, 0x97); ptr_write_i32(s, 134, 0x44); ptr_write_i32(s, 135, 0x17);
    ptr_write_i32(s, 136, 0xC4); ptr_write_i32(s, 137, 0xA7); ptr_write_i32(s, 138, 0x7E); ptr_write_i32(s, 139, 0x3D);
    ptr_write_i32(s, 140, 0x64); ptr_write_i32(s, 141, 0x5D); ptr_write_i32(s, 142, 0x19); ptr_write_i32(s, 143, 0x73);
    // Row 9
    ptr_write_i32(s, 144, 0x60); ptr_write_i32(s, 145, 0x81); ptr_write_i32(s, 146, 0x4F); ptr_write_i32(s, 147, 0xDC);
    ptr_write_i32(s, 148, 0x22); ptr_write_i32(s, 149, 0x2A); ptr_write_i32(s, 150, 0x90); ptr_write_i32(s, 151, 0x88);
    ptr_write_i32(s, 152, 0x46); ptr_write_i32(s, 153, 0xEE); ptr_write_i32(s, 154, 0xB8); ptr_write_i32(s, 155, 0x14);
    ptr_write_i32(s, 156, 0xDE); ptr_write_i32(s, 157, 0x5E); ptr_write_i32(s, 158, 0x0B); ptr_write_i32(s, 159, 0xDB);
    // Row A
    ptr_write_i32(s, 160, 0xE0); ptr_write_i32(s, 161, 0x32); ptr_write_i32(s, 162, 0x3A); ptr_write_i32(s, 163, 0x0A);
    ptr_write_i32(s, 164, 0x49); ptr_write_i32(s, 165, 0x06); ptr_write_i32(s, 166, 0x24); ptr_write_i32(s, 167, 0x5C);
    ptr_write_i32(s, 168, 0xC2); ptr_write_i32(s, 169, 0xD3); ptr_write_i32(s, 170, 0xAC); ptr_write_i32(s, 171, 0x62);
    ptr_write_i32(s, 172, 0x91); ptr_write_i32(s, 173, 0x95); ptr_write_i32(s, 174, 0xE4); ptr_write_i32(s, 175, 0x79);
    // Row B
    ptr_write_i32(s, 176, 0xE7); ptr_write_i32(s, 177, 0xC8); ptr_write_i32(s, 178, 0x37); ptr_write_i32(s, 179, 0x6D);
    ptr_write_i32(s, 180, 0x8D); ptr_write_i32(s, 181, 0xD5); ptr_write_i32(s, 182, 0x4E); ptr_write_i32(s, 183, 0xA9);
    ptr_write_i32(s, 184, 0x6C); ptr_write_i32(s, 185, 0x56); ptr_write_i32(s, 186, 0xF4); ptr_write_i32(s, 187, 0xEA);
    ptr_write_i32(s, 188, 0x65); ptr_write_i32(s, 189, 0x7A); ptr_write_i32(s, 190, 0xAE); ptr_write_i32(s, 191, 0x08);
    // Row C
    ptr_write_i32(s, 192, 0xBA); ptr_write_i32(s, 193, 0x78); ptr_write_i32(s, 194, 0x25); ptr_write_i32(s, 195, 0x2E);
    ptr_write_i32(s, 196, 0x1C); ptr_write_i32(s, 197, 0xA6); ptr_write_i32(s, 198, 0xB4); ptr_write_i32(s, 199, 0xC6);
    ptr_write_i32(s, 200, 0xE8); ptr_write_i32(s, 201, 0xDD); ptr_write_i32(s, 202, 0x74); ptr_write_i32(s, 203, 0x1F);
    ptr_write_i32(s, 204, 0x4B); ptr_write_i32(s, 205, 0xBD); ptr_write_i32(s, 206, 0x8B); ptr_write_i32(s, 207, 0x8A);
    // Row D
    ptr_write_i32(s, 208, 0x70); ptr_write_i32(s, 209, 0x3E); ptr_write_i32(s, 210, 0xB5); ptr_write_i32(s, 211, 0x66);
    ptr_write_i32(s, 212, 0x48); ptr_write_i32(s, 213, 0x03); ptr_write_i32(s, 214, 0xF6); ptr_write_i32(s, 215, 0x0E);
    ptr_write_i32(s, 216, 0x61); ptr_write_i32(s, 217, 0x35); ptr_write_i32(s, 218, 0x57); ptr_write_i32(s, 219, 0xB9);

    ptr_write_i32(s, 244, 0xBF); ptr_write_i32(s, 245, 0xE6); ptr_write_i32(s, 246, 0x42); ptr_write_i32(s, 247, 0x68);
    ptr_write_i32(s, 248, 0x41); ptr_write_i32(s, 249, 0x99); ptr_write_i32(s, 250, 0x2D); ptr_write_i32(s, 251, 0x0F);
    ptr_write_i32(s, 252, 0xB0); ptr_write_i32(s, 253, 0x54); ptr_write_i32(s, 254, 0xBB); ptr_write_i32(s, 255, 0x16);
}

// ---------------------------------------------------------------------------
// Inverse S-box initialization
// ---------------------------------------------------------------------------
fn init_rsbox(rs: ptr[i32]) {
    ptr_write_i32(rs, 0, 0x52); ptr_write_i32(rs, 1, 0x09); ptr_write_i32(rs, 2, 0x6A); ptr_write_i32(rs, 3, 0xD5);
    ptr_write_i32(rs, 4, 0x30); ptr_write_i32(rs, 5, 0x36); ptr_write_i32(rs, 6, 0xA5); ptr_write_i32(rs, 7, 0x38);
    ptr_write_i32(rs, 8, 0xBF); ptr_write_i32(rs, 9, 0x40); ptr_write_i32(rs, 10, 0xA3); ptr_write_i32(rs, 11, 0x9E);
    ptr_write_i32(rs, 12, 0x81); ptr_write_i32(rs, 13, 0xF3); ptr_write_i32(rs, 14, 0xD7); ptr_write_i32(rs, 15, 0xFB);
    ptr_write_i32(rs, 16, 0x7C); ptr_write_i32(rs, 17, 0xE3); ptr_write_i32(rs, 18, 0x39); ptr_write_i32(rs, 19, 0x82);

// ---------------------------------------------------------------------------
// Benchmark: Inflate
// ---------------------------------------------------------------------------
fn bench_inflate() {
    print("\n--- Benchmark: Inflate 4KB x 50K ---\n");

    let src_len: i32 = 4096;
    let src: ptr[i32] = heap_alloc(src_len, 1);
    for i: i32 in range(0, src_len) {
        ptr_write_u8(src, i, band(i *% 37 + 13, 255));
    }

    // Build length/distance tables
    let len_base: ptr[i32] = heap_alloc(29, 4);
    let len_extra: ptr[i32] = heap_alloc(29, 4);
    let dist_base: ptr[i32] = heap_alloc(30, 4);
    let dist_extra: ptr[i32] = heap_alloc(30, 4);
    build_length_table(len_base, len_extra);
    build_distance_table(dist_base, dist_extra);

    // Compress once
    let comp_max: i32 = src_len * 2 + 16;
    let comp: ptr[i32] = heap_alloc_zeroed(comp_max, 1);
    let comp_bits: i32 = deflate_fixed_literals(src, src_len, comp, comp_max * 8);

    let decomp: ptr[i32] = heap_alloc(src_len + 64, 1);
    let iterations: i32 = 50000;
    let checksum: i32 = 0;

    let t0: i64 = clock_ns();
    for iter: i32 in range(0, iterations) {
        let dlen: i32 = inflate_fixed(comp, 3, decomp, src_len + 64,
                                       len_base, len_extra, dist_base, dist_extra);
        checksum = checksum +% dlen;
    }
    let t1: i64 = clock_ns();
    let elapsed_ms: i64 = (t1 - t0) / 1000000;

    print("Elapsed: ");
    print_i64(elapsed_ms);
    print(" ms\n");
    print("Checksum (prevent DCE): ");
    print_i32(checksum);
    print("\n");

    if elapsed_ms > 0 {
        let total_mb: i64 = (widen(iterations) * widen(src_len)) / 1048576;
        let throughput: i64 = (total_mb * 1000) / elapsed_ms;
        print("Throughput: ");
        print_i64(throughput);
        print(" MB/s\n");
    }

    heap_free(src);
    heap_free(comp);
    heap_free(decomp);
    heap_free(len_base);
    heap_free(len_extra);
    heap_free(dist_base);
    heap_free(dist_extra);
}

// ---------------------------------------------------------------------------
// Main
// ---------------------------------------------------------------------------
fn main() -> i32 {
    print("=== lodepng Core: CRC32 + Adler32 + Inflate ===\n\n");

    let pass1: i32 = test_crc32();
    let pass2: i32 = test_adler32();
    let pass3: i32 = test_inflate();

    if pass1 == 1 and pass2 == 1 and pass3 == 1 {
        print("\nAll tests passed.\n");
    } else {
        print("\nSome tests FAILED.\n");
        return 1;
    }

    bench_crc32();
    bench_adler32();
    bench_inflate();

    print("\n=== lodepng complete ===\n");
    return 0;
}

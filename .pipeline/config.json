{
  "pipeline_version": "1.0",
  "project": "axiom",
  "description": "Multi-agent development pipeline for the AXIOM compiler",

  "agents": {
    "architect": {
      "description": "Designs specifications, API signatures, and acceptance criteria",
      "template": "templates/architect.md",
      "creates_branch": true,
      "branch_prefix": "architect"
    },
    "coder": {
      "description": "Implements Rust code from architect specifications",
      "template": "templates/coder.md",
      "creates_branch": true,
      "branch_prefix": "coder"
    },
    "reviewer": {
      "description": "Reviews code against spec and project conventions",
      "template": "templates/reviewer.md",
      "creates_branch": false,
      "branch_prefix": null
    },
    "tester": {
      "description": "Writes and runs tests to verify implementation",
      "template": "templates/tester.md",
      "creates_branch": true,
      "branch_prefix": "tester"
    },
    "benchmark": {
      "description": "Measures performance and detects regressions",
      "template": "templates/benchmark.md",
      "creates_branch": false,
      "branch_prefix": null
    }
  },

  "workflow": {
    "sequence": ["architect", "coder", "reviewer", "tester", "benchmark"],
    "retry_policy": {
      "max_coder_retries": 3,
      "max_architect_retries": 2,
      "max_reviewer_cycles": 3
    },
    "on_reviewer_request_changes": "retry_coder",
    "on_reviewer_reject": "retry_architect",
    "on_tester_fail": "retry_coder",
    "on_benchmark_regression": "retry_coder"
  },

  "git": {
    "strategy": "branch_and_merge",
    "merge_strategy": "--no-ff",
    "protected_branch": "main",
    "branch_naming": "{agent}/{run_id}/{milestone_id}",
    "pr_mode": false
  },

  "timeouts": {
    "agent_timeout_seconds": 600,
    "gate_check_timeout_seconds": 120
  },

  "required_tools": ["cargo", "rustc", "jq", "git", "claude"],
  "optional_tools": ["llc", "llvm-as", "mlir-opt", "clippy"]
}
